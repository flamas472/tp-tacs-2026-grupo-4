@page "/"
@inject AuthStateService AuthState

<PageTitle>Inicio — FiguriTACS</PageTitle>

@* ═══ HERO ═════════════════════════════════════════════════════════════════ *@
<div class="home-hero">
    <div class="home-hero-content">
        <MudText Typo="Typo.h3" Class="home-hero-title">
            Figuri<span style="color:var(--mud-palette-primary);font-weight:900">TACS</span>
        </MudText>
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="home-hero-subtitle mt-1">
            La plataforma de intercambio de figuritas del mundial
        </MudText>
        <MudText Typo="Typo.body1" Class="home-hero-desc mt-3">
            Publicá tus figuritas repetidas, registrá tus faltantes y preparate para intercambiarlas.
            Recibí sugerencias automáticas para intercambios y crea subastas para tus figuritas, o participá en las de otros usuarios.
            Todo en un solo lugar, de la manera más simple y rápida posible.
        </MudText>

        <AuthorizeView>
            <Authorized>
                <div class="home-welcome-row mt-4 mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.WavingHand" Color="Color.Warning" Size="Size.Small" />
                    <MudText Typo="Typo.body1">
                        Bienvenido/a de nuevo, <b>@AuthState.Username</b>
                    </MudText>
                </div>
                <div class="home-btn-group">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.CollectionsBookmark"
                               Href="/repetidas">
                        Mi colección
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Storefront"
                               Href="/mercado">
                        Ir al mercado
                    </MudButton>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="home-btn-group mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               Href="/ingresar">
                        Registrarse
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.Login"
                               Href="/ingresar">
                        Iniciar sesión
                    </MudButton>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    <div class="home-hero-visual" aria-hidden="true">
        <MudIcon Icon="@Icons.Material.Filled.Style" Class="home-hero-icon-bg" />
    </div>
</div>

@* ═══ ACCESOS RÁPIDOS (solo autenticados) ════════════════════════════════ *@
<AuthorizeView>
    <Authorized>
        <MudDivider Class="my-5" />
        <MudText Typo="Typo.subtitle1" Class="mb-3"><b>Accesos rápidos</b></MudText>
        <div class="home-quick-access">
            @foreach (var qa in QuickAccess)
            {
                <MudTooltip Text="@qa.Label" Placement="Placement.Top">
                    <MudPaper Class="home-qa-card" Elevation="1">
                        <MudIconButton Icon="@qa.Icon" Color="@qa.Color"
                                       Href="@qa.Href" Size="Size.Large" />
                        <MudText Typo="Typo.caption" Class="home-qa-label">@qa.Label</MudText>
                    </MudPaper>
                </MudTooltip>
            }
        </div>
    </Authorized>
</AuthorizeView>

<MudDivider Class="my-6" />

@* ═══ GRILLA DE FUNCIONALIDADES ══════════════════════════════════════════ *@
<div class="home-features-header mb-5">
    <MudText Typo="Typo.h5">¿Qué podés hacer en FiguriTACS?</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
        Todas las herramientas que necesitás para completar tu álbum del mundial
    </MudText>
</div>

<div class="home-features-grid">
    @foreach (var feature in Features)
    {
        <MudPaper Class="home-feature-card" Elevation="2">
            <div class="home-feature-top">
                <div class="home-feature-icon-wrap" style="background: @feature.BgColor;">
                    <MudIcon Icon="@feature.Icon" Color="@feature.Color" Size="Size.Medium" />
                </div>
                <MudText Typo="Typo.subtitle2" Class="home-feature-title mt-2">
                    <b>@feature.Title</b>
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="home-feature-desc mt-1">
                    @feature.Description
                </MudText>
            </div>
            <div class="home-feature-footer">
                @if (feature.Href != null)
                {
                    <AuthorizeView>
                        <Authorized>
                            <MudButton Variant="Variant.Text" Color="Color.Primary"
                                       Size="Size.Small"
                                       Href="@feature.Href"
                                       EndIcon="@Icons.Material.Filled.ArrowForward">
                                @feature.ActionLabel
                            </MudButton>
                        </Authorized>
                        <NotAuthorized>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Icon="@Icons.Material.Filled.Lock">
                                Requiere cuenta
                            </MudChip>
                        </NotAuthorized>
                    </AuthorizeView>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Icon="@Icons.Material.Outlined.Schedule">
                        Próximamente
                    </MudChip>
                }
            </div>
        </MudPaper>
    }
</div>

@* ═══ CTA FINAL (solo no autenticados) ═══════════════════════════════════ *@
<AuthorizeView>
    <NotAuthorized>
        <div class="home-cta-section mt-8">
            <MudPaper Class="home-cta-paper" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents"
                         Color="Color.Warning" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.h6" Class="mb-2">¿Listo para empezar?</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Creá tu cuenta gratis y comenzá a intercambiar figuritas del mundial hoy mismo.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           Href="/ingresar">
                    Crear cuenta gratis
                </MudButton>
            </MudPaper>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private record QuickAccessItem(string Icon, Color Color, string Label, string Href);
    private record FeatureItem(string Icon, Color Color, string BgColor,
                               string Title, string Description, string ActionLabel, string? Href);

    private static readonly QuickAccessItem[] QuickAccess =
