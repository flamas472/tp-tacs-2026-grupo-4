            "Ir a Faltantes", "/faltantes"),

        new(Icons.Material.Filled.Search,
            Color.Default,   "rgba(180,180,200,0.1)",
            "Búsqueda en el Mercado",
            "Explorá figuritas disponibles de todos los usuarios con filtros por número, selección, equipo y jugador.",
            "Ir al Mercado", "/mercado"),

        new(Icons.Material.Filled.Lightbulb,
            Color.Success,   "rgba(61,203,108,0.1)",
