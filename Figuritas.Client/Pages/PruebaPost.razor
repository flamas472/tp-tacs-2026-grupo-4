@page "/pruebapost"
@using Figuritas.Shared.Model
@inject HttpClient Http

<h3>Prueba de Registro de Usuario</h3>

<div class="card p-3" style="max-width: 400px;">
    <div class="mb-3">
        <label>Nombre de Usuario:</label>
        <input @bind="userDto.Username" class="form-control" placeholder="Ej: messi10" />
    </div>
    <div class="mb-3">
        <label>Contraseña:</label>
        <input @bind="userDto.Password" type="password" class="form-control" />
    </div>

    <button class="btn btn-primary" @onclick="GuardarUsuario">Registrar Usuario</button>
</div>

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert @claseAlert mt-3">
        @mensaje
    </div>
}

@code {
    // Usamos una clase interna o la del Shared para el DTO
    private PostUserDto userDto = new PostUserDto();
    private string mensaje = "";
    private string claseAlert = "";

    private async Task GuardarUsuario()
    {
        try
        {
            // El endpoint ahora es api/Users (asumiendo que el controlador se llama UsersController)
            var response = await Http.PostAsJsonAsync("api/Users", userDto);

            if (response.IsSuccessStatusCode)
            {
                var usuarioCreado = await response.Content.ReadFromJsonAsync<User>();
                mensaje = $"Usuario creado con éxito! ID: {usuarioCreado?.Id}";
                claseAlert = "alert-success";
                userDto = new PostUserDto(); // Limpiar formulario
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                mensaje = $"Error en el servidor: {error}";
                claseAlert = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error de conexión: {ex.Message}";
            claseAlert = "alert-danger";
        }
    }

    // Definición local del DTO para evitar problemas de referencia si no está en el Shared
    public class PostUserDto
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }

    // Clase espejo para recibir la respuesta (ajustar según tu modelo User)
    public class User 
    {
        public int Id { get; set; }
        public string Username { get; set; } = "";
    }
}