@page "/catalogo"
@using Figuritas.Client.Requests
@using Figuritas.Shared.Model

@inject IDialogService DialogService
@inject AuthStateService AuthState
@inject StickerHttpClient StickerHttp
@inject NationalTeamHttpClient NationalTeamHttp
@inject CategoryHttpClient CategoryHttp

<PageTitle>Catálogo de figuritas</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Catálogo</MudText>

<MudPaper Class="filters-panel" Elevation="1">
    <p class="filters-title">Filtros</p>
    <div class="filters-row">
        <MudSelect T="string"
                   Label="Selección"
                   Value="@filtroNationalTeam"
                   ValueChanged="OnFiltroNationalTeamChanged"
                   Class="filter-select"
                   Clearable="true">
            <MudSelectItem Value="@(string.Empty)">Todas las selecciones</MudSelectItem>
            @foreach (var nt in nationalTeams ?? new List<NationalTeam>())
            {
                <MudSelectItem Value="@nt.Description">@nt.Description</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="string"
                   Label="Categoría"
                   Value="@filtroCategory"
                   ValueChanged="OnFiltroCategoryChanged"
                   Class="filter-select"
                   Clearable="true">
            <MudSelectItem Value="@(string.Empty)">Todas las categorías</MudSelectItem>
            @foreach (var cat in categories ?? new List<Category>())
            {
                <MudSelectItem Value="@cat.Description">@cat.Description</MudSelectItem>
            }
        </MudSelect>
    </div>
</MudPaper>

@if (errorMessage != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        No se pudo cargar el catálogo: @errorMessage
    </MudAlert>
}

<StickerListComponent Stickers="@stickers"
                      OnStickerClick="OnStickerClick"
                      OnNextPage="HandleNextPage"
                      OnPrevPage="HandlePrevPage"
                      HasNextPage="@hasNextPage"
                      HasPrevPage="@hasPrevPage"
                      CurrentPage="@currentPage" />

@code {
    private const int PageSize = 24;

    private List<Sticker>? stickers;
    private List<NationalTeam>? nationalTeams;
    private List<Category>? categories;

    private string filtroNationalTeam = string.Empty;
    private string filtroCategory = string.Empty;
    private string? errorMessage;

    private int currentPage = 1;
    private bool hasNextPage;
    private bool hasPrevPage => currentPage > 1;

    protected override async Task OnInitializedAsync()
    {
        var ntTask = NationalTeamHttp.GetNationalTeamsAsync();
        var catTask = CategoryHttp.GetCategoriesAsync();

        await Task.WhenAll(ntTask, catTask);

        var ntResponse = ntTask.Result;
        var catResponse = catTask.Result;

        if (ntResponse.Success)
            nationalTeams = ntResponse.Data?.OrderBy(nt => nt.Description).ToList();

        if (catResponse.Success)
            categories = catResponse.Data?.OrderBy(c => c.Description).ToList();

        await FetchStickers();
    }

    private async Task OnFiltroNationalTeamChanged(string value)
    {
        filtroNationalTeam = value;
        currentPage = 1;
        await FetchStickers();
    }

    private async Task OnFiltroCategoryChanged(string value)
    {
        filtroCategory = value;
        currentPage = 1;
        await FetchStickers();
    }

    private async Task HandleNextPage()
    {
        currentPage++;
        await FetchStickers();
    }

    private async Task HandlePrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await FetchStickers();
        }
    }

    private async Task FetchStickers()
    {
        stickers = null;
        StateHasChanged();

        var response = await StickerHttp.GetStickersAsync(
            page: currentPage,
            pageSize: PageSize,
            nationalTeam: filtroNationalTeam,
            category: filtroCategory
        );

        if (response.Success)
        {
            errorMessage = null;
            stickers = response.Data?.OrderBy(s => s.Number).ToList() ?? new List<Sticker>();
            hasNextPage = stickers.Count == PageSize;
        }
        else
        {
            stickers = new List<Sticker>();
            hasNextPage = false;
            errorMessage = response.ErrorMessage;
        }
    }

    private async Task OnStickerClick(Sticker sticker)
    {
        var parameters = new DialogParameters<StickerActionDialog>
        {
            { d => d.Sticker, sticker },
            { d => d.IsAuthenticated, AuthState.UserId != 0 }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };
        await DialogService.ShowAsync<StickerActionDialog>(
            $"#{sticker.Number:D3} — {sticker.Description}",
            parameters, options);
    }
}
