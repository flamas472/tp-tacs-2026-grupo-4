@page "/catalogo"
@using Figuritas.Client.Components;
@using Figuritas.Client.Extensions;
@using Figuritas.Shared.Responses;
@using Figuritas.Client.Requests;

@inject StickerHttpClient StickerHttp
@inject HttpClient Http
@using Figuritas.Shared.Model

<PageTitle>Catálogo</PageTitle>


@* FILTROS *@
<MudPaper Style="padding: 1rem; margin-bottom: 1rem;">
    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem;">
        <MudSelect
            T="string"
            Label="Selección"
            Value="@filtroNationalTeam"
            ValueChanged="@OnFiltroNationalTeamIdChanged"
            Style="min-width: 240px;"
        >
            <MudSelectItem Value="@(string.Empty)">Todas las selecciones</MudSelectItem>
            @foreach (NationalTeam nationalTeam in nationalTeams ?? new List<NationalTeam>())
            {
                <MudSelectItem Value="@(nationalTeam.Description)">@nationalTeam.Description</MudSelectItem>
            }
        </MudSelect>

        <MudSelect
            T="string"
            Label="Categoría"
            Value="@filtroCategory"
            ValueChanged="@OnFiltroCategoryIdChanged"
            Style="min-width: 240px;"
        >
            <MudSelectItem Value="@(string.Empty)">Todas las categorías</MudSelectItem>
            @foreach (Category category in category ?? new List<Category>())
            {
                <MudSelectItem Value="@(category.Description)">@category.Description</MudSelectItem>
            }
        </MudSelect>
    </div>
</MudPaper>

@* LISTADO DE FIGURITAS *@
@if (stickers == null)
{
    <MudPaper Style="padding: 1rem;">
        <MudText Typo="Typo.subtitle1">@mensajeFetch</MudText>
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Style="margin-top: 1rem;" />
    </MudPaper>
}
else if (!stickers.Any())
{
    <MudPaper Style="padding: 1rem;">
        <MudText Typo="Typo.subtitle1">No se encontraron figuritas</MudText>
    </MudPaper>
}
else
{
    <MudGrid GutterSize="3">
        @foreach (Sticker sticker in stickers)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <StickerComponent sticker="@sticker" @key="sticker.Id" />
            </MudItem>
        }
    </MudGrid>
}



@code {
    private List<Sticker>? stickers;
    private List<NationalTeam>? nationalTeams;
    private List<Category>? category;
    private string mensajeFetch = "Cargando figuritas...";
    private string filtroNationalTeam = "";
    private string filtroCategory = "";

    private async Task OnFiltroNationalTeamIdChanged(string value)
    {
        filtroNationalTeam = value;
        await FetchStickers();
    }

    private async Task OnFiltroCategoryIdChanged(string value)
    {
        filtroCategory = value;
        await FetchStickers();
    }
    
    private async Task FetchStickers()
    {
        mensajeFetch = "Cargando figuritas...";
        stickers = null; // Esto hace que se muestre el mensaje de "Cargando figuritas..." mientras se hace la petición
        StateHasChanged(); // Forzamos a Blazor a actualizar la UI antes de hacer la petición
        ApiResponse<List<Sticker>> response = await StickerHttp.GetStickersAsync(
            page: 1,
            pageSize: 20,
            nationalTeam: filtroNationalTeam,
            category: filtroCategory
            );
            
        if (response.Success)
        {
            stickers = response.Data;
        }
        else
        {
            mensajeFetch = "Error al cargar figuritas: " + response.ErrorMessage;
            Console.WriteLine(mensajeFetch);
        }
    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var nationalTeamsTask = Http.GetAsync("api/NationalTeam");
            var categoryTask = Http.GetAsync("api/Category");
            
            await Task.WhenAll(nationalTeamsTask, categoryTask);

            nationalTeams = await nationalTeamsTask.Result.ProcesarRespuesta<List<NationalTeam>>();
            category = await categoryTask.Result.ProcesarRespuesta<List<Category>>();

            if (nationalTeams != null)
            {
                nationalTeams = nationalTeams.OrderBy(nt => nt.Description).ToList();
            }
            if (category != null)
            {
                category = category.OrderBy(c => c.Description).ToList();
            }


            await FetchStickers();
            
            
        }
        catch (Exception ex)
        {

            mensajeFetch = "Error en petición http: " + ex.Message;
            Console.WriteLine(mensajeFetch);
        }
    }
    
}