@page "/admin/estadisticas"
@attribute [Authorize]

@inject AuthStateService AuthState
@inject NavigationManager Nav

<PageTitle>Estadísticas — Figuritas</PageTitle>

<UnderConstruction Section="Estadísticas de la plataforma"
                   Stories="@(new (int, string)[]{
                       (12, "Como administrador quiero ver estadísticas de uso y actividad de la plataforma.")
                   })" />

@code {
    protected override void OnInitialized()
    {
        if (!AuthState.IsAdmin)
            Nav.NavigateTo("/");
    }
}
