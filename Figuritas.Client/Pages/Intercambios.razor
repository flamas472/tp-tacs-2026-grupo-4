@page "/intercambios"
@attribute [Authorize]
@using Figuritas.Shared.Model.Intercambios

<PageTitle>Intercambios — FiguriTACS</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Intercambios finalizados</MudText>

@* ── Mobile/tablet: pestañas ── *@
<MudHidden Breakpoint="Breakpoint.LgAndUp">
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="Recibidas" Icon="@Icons.Material.Filled.MoveToInbox">
            <div class="pt-3">
                <ProposalListPanel IsSent="false" AllowedStates="@FilterStates" />
            </div>
        </MudTabPanel>
        <MudTabPanel Text="Enviadas" Icon="@Icons.Material.Filled.Send">
            <div class="pt-3">
                <ProposalListPanel IsSent="true" AllowedStates="@FilterStates" />
            </div>
        </MudTabPanel>
    </MudTabs>
</MudHidden>

@* ── Desktop: dos columnas ── *@
<MudHidden Breakpoint="Breakpoint.MdAndDown">
    <MudGrid>
        <MudItem xs="12" lg="6">
            <MudText Typo="Typo.h6" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.MoveToInbox" Size="Size.Small" Class="mr-1" />
                Recibidas
            </MudText>
            <ProposalListPanel IsSent="false" AllowedStates="@FilterStates" />
        </MudItem>
        <MudItem xs="12" lg="6">
            <MudText Typo="Typo.h6" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" Class="mr-1" />
                Enviadas
            </MudText>
            <ProposalListPanel IsSent="true" AllowedStates="@FilterStates" />
        </MudItem>
    </MudGrid>
</MudHidden>

@code {
    private static readonly List<ExchangeProposalState> FilterStates = new()
    {
        ExchangeProposalState.Accepted
    };
}
