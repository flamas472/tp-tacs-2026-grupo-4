@page "/faltantes"
@attribute [Authorize]
@using Figuritas.Client.Requests
@using Figuritas.Shared.Model

@inject IDialogService DialogService
@inject AuthStateService AuthState
@inject UserHttpClient UserHttp
@inject StickerHttpClient StickerHttp
@inject NationalTeamHttpClient NationalTeamHttp
@inject CategoryHttpClient CategoryHttp

<PageTitle>Mis figuritas faltantes</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Figuritas faltantes</MudText>

<MudPaper Class="filters-panel" Elevation="1">
    <p class="filters-title">Filtros</p>
    <div class="filters-row">
        <MudSelect T="string"
                   Label="Selección"
                   Value="@filtroNationalTeam"
                   ValueChanged="OnFiltroNationalTeamChanged"
                   Class="filter-select"
                   Clearable="true">
            <MudSelectItem Value="@(string.Empty)">Todas las selecciones</MudSelectItem>
            @foreach (var nt in nationalTeams ?? new List<NationalTeam>())
            {
                <MudSelectItem Value="@nt.Description">@nt.Description</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="string"
                   Label="Categoría"
                   Value="@filtroCategory"
                   ValueChanged="OnFiltroCategoryChanged"
                   Class="filter-select"
                   Clearable="true">
            <MudSelectItem Value="@(string.Empty)">Todas las categorías</MudSelectItem>
            @foreach (var cat in categories ?? new List<Category>())
            {
                <MudSelectItem Value="@cat.Description">@cat.Description</MudSelectItem>
            }
        </MudSelect>
    </div>
</MudPaper>

<StickerListComponent Stickers="@stickers"
                      OnStickerClick="OnStickerClick"
                      OnNextPage="HandleNextPage"
                      OnPrevPage="HandlePrevPage"
                      HasNextPage="@hasNextPage"
                      HasPrevPage="@hasPrevPage"
                      CurrentPage="@currentPage" />

@code {
    private const int PageSize = 24;

    private List<Sticker>? stickers;
    private List<NationalTeam>? nationalTeams;
    private List<Category>? categories;

    private string filtroNationalTeam = string.Empty;
    private string filtroCategory = string.Empty;

    private int currentPage = 1;
    private bool hasNextPage;
    private bool hasPrevPage => currentPage > 1;

    protected override async Task OnInitializedAsync()
    {
        var ntTask = NationalTeamHttp.GetNationalTeamsAsync();
        var catTask = CategoryHttp.GetCategoriesAsync();

        await Task.WhenAll(ntTask, catTask);

        if (ntTask.Result.Success)
            nationalTeams = ntTask.Result.Data?.OrderBy(nt => nt.Description).ToList();

        if (catTask.Result.Success)
            categories = catTask.Result.Data?.OrderBy(c => c.Description).ToList();

        await FetchStickers();
    }

    private async Task OnFiltroNationalTeamChanged(string value)
    {
        filtroNationalTeam = value;
        currentPage = 1;
        await FetchStickers();
    }

    private async Task OnFiltroCategoryChanged(string value)
    {
        filtroCategory = value;
        currentPage = 1;
        await FetchStickers();
    }

    private async Task HandleNextPage()
    {
        currentPage++;
        await FetchStickers();
    }

    private async Task HandlePrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await FetchStickers();
        }
    }

    private async Task FetchStickers()
    {
        stickers = null;
        StateHasChanged();

        var missingResponse = await UserHttp.GetMissingStickersAsync(AuthState.UserId);
        if (!missingResponse.Success || missingResponse.Data == null)
        {
            stickers = new List<Sticker>();
            hasNextPage = false;
            Console.WriteLine($"Error al cargar faltantes: {missingResponse.ErrorMessage}");
            return;
        }

        var missingIds = missingResponse.Data.Select(m => m.StickerId).ToHashSet();
        if (!missingIds.Any())
        {
            stickers = new List<Sticker>();
            hasNextPage = false;
            return;
        }

        // Obtiene el catálogo aplicando los filtros y luego cruza con los IDs faltantes
        var catalogResponse = await StickerHttp.GetStickersAsync(
            page: 1, pageSize: 500,
            nationalTeam: filtroNationalTeam,
            category: filtroCategory
        );

        if (!catalogResponse.Success)
        {
            stickers = new List<Sticker>();
            hasNextPage = false;
            Console.WriteLine($"Error al cargar catálogo: {catalogResponse.ErrorMessage}");
            return;
        }

        var allFiltered = (catalogResponse.Data ?? new List<Sticker>())
            .Where(s => missingIds.Contains(s.Id))
            .OrderBy(s => s.Number)
            .ToList();

        var skip = (currentPage - 1) * PageSize;
        stickers = allFiltered.Skip(skip).Take(PageSize).ToList();
        hasNextPage = allFiltered.Count > skip + PageSize;
    }

    private async Task OnStickerClick(Sticker sticker)
    {
        var parameters = new DialogParameters<MissingStickerActionDialog>
        {
            { d => d.Sticker, sticker }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };
        var dialog = await DialogService.ShowAsync<MissingStickerActionDialog>(
            $"#{sticker.Number:D3} — {sticker.Description}",
            parameters, options);

        var result = await dialog.Result;
        if (result is { Canceled: false })
            await FetchStickers();
    }
}
