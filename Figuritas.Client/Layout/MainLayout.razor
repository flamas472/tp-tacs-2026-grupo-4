@inherits LayoutComponentBase

<div class="min-h-screen bg-gray-50 text-gray-900 flex flex-col">
    <!-- Header -->
    <header class="bg-white border-b border-gray-200 py-4 shadow-sm">
        <div class="container mx-auto px-4 flex justify-between items-center">
            <NavLink href="/" class="flex items-center gap-2 text-gray-900">
                <span class="text-2xl">⚽</span>
                <h1 class="text-xl font-bold" ActiveClass="text-green-700 font-bold">FiguriTACS</h1>
            </NavLink>
            
            <nav class="flex gap-6 font-medium">
                <NavLink href="" Match="NavLinkMatch.All" class="text-gray-600 hover:text-green-700 transition" ActiveClass="text-green-700 font-bold">
                    Inicio
                </NavLink>
                <NavLink href="catalogo" class="text-gray-600 hover:text-green-700 transition" ActiveClass="text-green-700 font-bold">
                    Catálogo
                </NavLink>
            </nav>
        </div>
    </header>

    <!-- Contenido dinámico -->
    <main class="flex-grow container mx-auto px-4 py-8">
        <div class="animate-in fade-in duration-500">
            @Body
        </div>
    </main>

    <!-- Footer Simple -->
    <footer class="bg-white border-t border-gray-200 py-6">
        <div class="container mx-auto px-4 text-center text-sm text-gray-500">
            &copy; 2026 - Proyecto Ingeniería de Software - Grupo 4
        </div>
    </footer>
</div>