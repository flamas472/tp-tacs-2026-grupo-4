@using Figuritas.Shared.Model
@using Figuritas.Shared.DTO
@using Figuritas.Shared.DTO.request
@using Figuritas.Shared.DTO.response
@using Figuritas.Client.Requests

@inject UserHttpClient UserHttp
@inject DashboardHttpClient DashboardHttp
@inject AuthStateService AuthState
@inject NavigationManager Nav

<MudDialog>
    <DialogContent>
        <StickerDialogContent Sticker="@Sticker"
                              FeedbackMsg="@feedbackMsg"
                              FeedbackSuccess="@feedbackSuccess"
                              FeedbackSeverity="@feedbackSeverity">
            @if (IsAuthenticated)
            {
                @if (initialLoading)
                {
                    <div class="d-flex justify-center mt-2 mb-1">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    </div>
                }
                else
                {
                    <div class="action-mode-selector">
                        <MudButton Variant="@(modoRepetida ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                   Class="action-mode-btn"
                                   OnClick="@(() => { modoRepetida = true; feedbackMsg = null; })">
                            Repetida
                        </MudButton>
                        <MudButton Variant="@(!modoRepetida ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.BookmarkAdd"
                                   Class="action-mode-btn"
                                   OnClick="@(() => { modoRepetida = false; feedbackMsg = null; })">
                            Faltante
                        </MudButton>
                    </div>

                    @if (modoRepetida)
                    {
                        <MudCheckBox @bind-Value="canBeExchanged"
                                     Label="Disponible para intercambio directo"
                                     Color="Color.Primary"
                                     Class="mt-1" />
                        <MudCheckBox @bind-Value="canBeAuctioned"
                                     Label="Disponible para subastar"
                                     Color="Color.Secondary"
                                     Class="mt-0" />
                    }
                }
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1 mb-2">
                    Iniciá sesión para gestionar tu colección.
                </MudText>
            }
        </StickerDialogContent>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())" Disabled="loading">Cerrar</MudButton>
        @if (IsAuthenticated)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="HandleAgregar"
                       Disabled="loading || initialLoading">
                @if (loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Agregar
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@(() => { MudDialog.Cancel(); Nav.NavigateTo("/ingresar"); })">
                Ir a Ingresar
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter][EditorRequired] public Sticker Sticker { get; set; } = default!;
    [Parameter] public bool IsAuthenticated { get; set; } = true;

    private bool modoRepetida = true;
    private bool canBeExchanged = true;
    private bool canBeAuctioned = false;
    private bool loading = false;
    private bool initialLoading = false;
    private MyPublishedStickerResponseDTO? cachedExisting = null;
    private string? feedbackMsg = null;
    private bool feedbackSuccess = false;
    private Severity feedbackSeverity = Severity.Error;

    protected override async Task OnInitializedAsync()
    {
        if (IsAuthenticated)
            await LoadExistingUserSticker();
    }

    private async Task LoadExistingUserSticker()
    {
        initialLoading = true;

        var result = await DashboardHttp.GetMyStickersAsync(1, 100);
        cachedExisting = result.Success
            ? result.Data?.FirstOrDefault(s => s.Number == Sticker.Number)
            : null;

        // Pre-poblar: si ya la tiene, usar sus valores; si no, intercambio=true, subasta=false
        canBeExchanged = cachedExisting?.CanBeDirectlyExchanged ?? true;
        canBeAuctioned = cachedExisting?.CanBeAuctioned ?? false;

        initialLoading = false;
    }

    private async Task HandleAgregar()
    {
        loading = true;
        feedbackMsg = null;
        feedbackSeverity = Severity.Error;

        var userId = AuthState.UserId;

        if (modoRepetida)
            await HandleRepetida(userId);
        else
            await HandleFaltante(userId);

        loading = false;

        if (feedbackSuccess)
        {
            await Task.Delay(1200);
            MudDialog.Close();
        }
    }

    private async Task HandleRepetida(int userId)
    {
        if (cachedExisting != null)
        {
            // Ya existe → PATCH: incrementar cantidad + actualizar booleanos
            var patchResult = await UserHttp.UpdateUserStickerAsync(
                userId, cachedExisting.StickerId,
                new PatchUserStickerDTO
                {
                    CanBeDirectlyExchanged = canBeExchanged,
                    CanBeAuctioned = canBeAuctioned,
                    Quantity = cachedExisting.Quantity + 1
                });

            feedbackSuccess = patchResult.Success;
            feedbackMsg = patchResult.Success
                ? "Repetida actualizada correctamente."
                : patchResult.ErrorMessage ?? "Error al actualizar la figurita.";
        }
        else
        {
            // No existe → POST
            var postResult = await UserHttp.AddUserStickerAsync(userId, new PostUserStickerRequestDTO
            {
                StickerId = Sticker.Id,
                Quantity = 1,
                CanBeDirectlyExchanged = canBeExchanged,
                CanBeAuctioned = canBeAuctioned
            });

            feedbackSuccess = postResult.Success;
            feedbackMsg = postResult.Success
                ? "Figurita agregada a tus repetidas."
                : postResult.ErrorMessage ?? "Error al agregar la figurita.";
        }
    }

    private async Task HandleFaltante(int userId)
    {
        var missingResult = await UserHttp.GetMissingStickersAsync(userId);
        var alreadyExists = missingResult.Success
            && (missingResult.Data?.Any(m => m.StickerId == Sticker.Id) ?? false);

        if (alreadyExists)
        {
            feedbackSuccess = false;
            feedbackSeverity = Severity.Warning;
            feedbackMsg = "Esta figurita ya está en tus faltantes.";
            return;
        }

        var postResult = await UserHttp.AddMissingStickerAsync(userId, new PostMissingStickerRequestDTO
        {
            StickerId = Sticker.Id
        });

        feedbackSuccess = postResult.Success;
        feedbackMsg = postResult.Success
            ? "Figurita agregada a tus faltantes."
            : postResult.ErrorMessage ?? "Error al agregar la figurita.";
    }
}
