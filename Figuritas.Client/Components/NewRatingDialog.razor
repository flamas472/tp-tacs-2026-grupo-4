@using Figuritas.Shared.DTO.request
@using Figuritas.Shared.DTO.response
@using Figuritas.Client.Requests

@inject ExchangeHttpClient ExchangeHttp
@inject ExchangeProposalHttpClient ProposalHttp
@inject AuthStateService AuthState

@* ──────────────────────────────────────────────────────────────────────────────
   NewRatingDialog — Diálogo para calificar al usuario contraparte luego de
   concretar un intercambio (US10), con soporte de modo lectura para ver una
   calificación ya emitida.

   Parámetros:
     Proposal        — propuesta de intercambio ya concretada
     CounterpartName — nombre del usuario a calificar
     CounterpartId   — ID del usuario a calificar
     IsReadOnly      — si es true, muestra la calificación existente sin permitir edición
     ExistingStars   — estrellas de la calificación ya emitida (solo en modo lectura)
     ExistingComment — comentario de la calificación ya emitida (solo en modo lectura)

   Cierra con DialogResult.Ok(proposalId) al calificar exitosamente, para que la
   página padre pueda marcar el intercambio como "ya calificado".
────────────────────────────────────────────────────────────────────────────── *@

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Star"
                     Color="@(IsReadOnly ? Color.Default : Color.Warning)" />
            <MudText Typo="Typo.h6">
                @if (IsReadOnly)
                {
                    <span>Tu calificación para: <strong>@CounterpartName</strong></span>
                }
                else
                {
                    <span>Calificando a: <strong>@CounterpartName</strong></span>
                }
            </MudText>
        </div>
    </TitleContent>

    <DialogContent>
        @* ── Modo lectura ─────────────────────────────────────────────────────── *@
        @if (IsReadOnly)
        {
            <div class="rating-stars-section mb-4">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Puntuación</MudText>
                <MudRating SelectedValue="@ExistingStars"
                           MaxValue="5"
                           Size="Size.Large"
                           Color="Color.Warning"
                           ReadOnly="true" />
            </div>

            @if (!string.IsNullOrWhiteSpace(ExistingComment))
            {
                <MudText Typo="Typo.subtitle2" Class="mb-1">Comentario</MudText>
                <MudPaper Elevation="0" Class="pa-3 mb-2" Style="background: var(--mud-palette-background-grey);">
                    <MudText Typo="Typo.body2">@ExistingComment</MudText>
                </MudPaper>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    No dejaste un comentario en esta calificación.
                </MudText>
            }
        }
        else
        {
            @* ── Modo edición ──────────────────────────────────────────────────── *@

            @* ── Error de carga del intercambio ────────────────────────────────── *@
            @if (loadError is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">
                    @loadError
                </MudAlert>
            }

            @* ── Estrellas ──────────────────────────────────────────────────────── *@
            <div class="rating-stars-section mb-4">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    Puntuación <span style="color:var(--mud-palette-error);">*</span>
                </MudText>
                <MudRating @bind-SelectedValue="selectedStars"
                           MaxValue="5"
                           Size="Size.Large"
                           Color="Color.Warning"
                           Disabled="@(isLoading || submitSuccess)" />
                @if (showStarsError)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">
                        Debes seleccionar al menos una estrella.
                    </MudText>
                }
            </div>

            @* ── Comentario ─────────────────────────────────────────────────────── *@
            <MudTextField @bind-Value="comment"
                          Label="Comentario (opcional)"
                          Lines="3"
                          MaxLength="500"
                          Variant="Variant.Outlined"
                          HelperText="@($"{comment?.Length ?? 0}/500 caracteres")"
                          Disabled="@(isLoading || submitSuccess)"
                          Class="mb-2" />

            @* ── Feedback de error de envío ──────────────────────────────────────── *@
            @if (submitError is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">
                    @submitError
                </MudAlert>
            }

            @* ── Feedback de éxito ───────────────────────────────────────────────── *@
            @if (submitSuccess)
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
                    ¡Calificación enviada exitosamente!
                </MudAlert>
            }
        }
    </DialogContent>

    <DialogActions>
        @if (IsReadOnly)
        {
            <MudButton OnClick="@(() => MudDialog.Cancel())">Cerrar</MudButton>
        }
        else
        {
            <MudButton OnClick="@(() => MudDialog.Cancel())"
                       Disabled="@isLoading">
                Cerrar
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.Star"
                       OnClick="HandleEnviarCalificacion"
                       Disabled="@(isLoading || submitSuccess || loadError is not null)">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Calificar
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    /// <summary>Instancia del diálogo MudBlazor.</summary>
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>Propuesta de intercambio concretada sobre la cual se emite la calificación.</summary>
    [Parameter][EditorRequired] public ExchangeProposalResponseDTO Proposal { get; set; } = default!;

    /// <summary>Nombre de usuario de la contraparte a calificar (calculado en la página padre).</summary>
    [Parameter][EditorRequired] public string CounterpartName { get; set; } = string.Empty;

    /// <summary>ID del usuario contraparte a calificar.</summary>
    [Parameter][EditorRequired] public int CounterpartId { get; set; }

    /// <summary>
    /// Cuando es true el diálogo funciona en modo lectura: muestra la calificación ya
    /// emitida (ExistingStars / ExistingComment) sin permitir edición ni envío.
    /// </summary>
    [Parameter] public bool IsReadOnly { get; set; }

    /// <summary>Estrellas de la calificación previamente emitida. Solo relevante cuando IsReadOnly = true.</summary>
    [Parameter] public int ExistingStars { get; set; }

    /// <summary>Comentario de la calificación previamente emitida. Solo relevante cuando IsReadOnly = true.</summary>
    [Parameter] public string? ExistingComment { get; set; }

    // ── Estado interno (solo modo edición) ───────────────────────────────────
    private int selectedStars = 0;
    private string? comment;
    private bool isLoading = false;
    private bool submitSuccess = false;
    private bool showStarsError = false;
    private string? submitError;
    private string? loadError;

    /// <summary>ID real del intercambio (obtenido desde la propuesta aceptada).</summary>
    private int? exchangeId;

    // ── Ciclo de vida ─────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        // En modo lectura no necesitamos resolver el Exchange ni cargar nada adicional
        if (IsReadOnly) return;

        // Resolvemos el ID real del Exchange a partir del ID de la propuesta
        isLoading = true;
        var result = await ProposalHttp.GetExchangeByProposalIdAsync(Proposal.Id);
        isLoading = false;

        if (result.Success && result.Data is not null)
        {
            exchangeId = result.Data.Id;
        }
        else
        {
            loadError = result.ErrorMessage ?? "No se pudo obtener el intercambio asociado.";
        }
    }

    // ── Handlers ──────────────────────────────────────────────────────────────

    /// <summary>Valida la selección y envía la calificación al backend.</summary>
    private async Task HandleEnviarCalificacion()
    {
        // Validación client-side: mínimo 1 estrella
        if (selectedStars < 1)
        {
            showStarsError = true;
            return;
        }
        showStarsError = false;
        submitError = null;

        if (exchangeId is null)
        {
            submitError = "No se pudo identificar el intercambio. Intentá cerrar y volver a abrir este diálogo.";
            return;
        }

        isLoading = true;

        var token = await AuthState.GetTokenAsync() ?? string.Empty;

        var dto = new PostRatingRequestDTO
        {
            ExchangeId   = exchangeId.Value,
            TargetUserId = CounterpartId,
            Stars        = selectedStars,
            Comment      = string.IsNullOrWhiteSpace(comment) ? null : comment.Trim()
        };

        var result = await ExchangeHttp.CreateRatingAsync(dto, token);
        isLoading = false;

        if (result.Success)
        {
            submitSuccess = true;
            // Breve pausa para que el usuario vea el mensaje de éxito antes de cerrar
            await Task.Delay(1200);
            MudDialog.Close(DialogResult.Ok(new RatingSubmitResult(Proposal.Id, selectedStars, comment?.Trim())));
        }
        else
        {
            submitError = result.ErrorMessage ?? "No se pudo enviar la calificación. Intente nuevamente.";
        }
    }

    /// <summary>
    /// Resultado devuelto al padre cuando se envía una calificación nueva exitosamente.
    /// Contiene el ProposalId y los valores de la calificación emitida para que el padre
    /// pueda actualizar su estado sin necesidad de un re-fetch.
    /// </summary>
    public record RatingSubmitResult(int ProposalId, int Stars, string? Comment);
}
