@using Figuritas.Shared.Model
@inject NavigationManager Nav

<MudCard Class="sticker-card" Elevation="2" @onclick="HandleCardClick">
    <div class="sticker-image-container">
        <img src="@Sticker.ImageUrl" alt="@Sticker.Description" class="sticker-image" />
        <span class="sticker-number-badge">@Sticker.Number.ToString("D3")</span>
        @if (Quantity > 0)
        {
            <span class="sticker-quantity-badge">@Quantity</span>
        }
    </div>
    <MudCardContent Class="sticker-info">
        <MudText Typo="Typo.subtitle2" Class="sticker-description">@Sticker.Description</MudText>
        <div class="sticker-meta">
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Sticker.NationalTeam</MudText>
            <MudText Typo="Typo.caption" Color="Color.Tertiary">@Sticker.Category</MudText>
        </div>
        @if (!string.IsNullOrEmpty(OwnerUsername))
        {
            <div class="sticker-owner-label sticker-owner-link"
                 role="button"
                 aria-label="@($"Ver perfil de {OwnerUsername}")"
                 tabindex="0"
                 @onclick:stopPropagation="true"
                 @onclick="NavigateToProfile"
                 @onkeydown:stopPropagation="true"
                 @onkeydown="HandleOwnerKeyDown">
                <MudIcon Icon="@Icons.Material.Filled.Person"
                         Size="Size.Small"
                         Style="font-size:0.7rem;vertical-align:middle;" />
                <MudText Typo="Typo.caption">@OwnerUsername</MudText>
                @if (OwnerReputation > 0)
                {
                    <span class="sticker-owner-rep">★ @OwnerReputation.ToString("F1")</span>
                }
            </div>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter][EditorRequired] public Sticker Sticker { get; set; } = default!;
    [Parameter] public int Quantity { get; set; } = 0;
    [Parameter] public EventCallback<Sticker> OnStickerClick { get; set; }
    /// <summary>Username del propietario a mostrar debajo de la selección. Si es null o vacío, no se renderiza.</summary>
    [Parameter] public string? OwnerUsername { get; set; }
    /// <summary>Reputación del propietario (0–5). Si es 0 no se muestra la calificación. Clickear navega a /perfil/{OwnerUsername}.</summary>
    [Parameter] public double OwnerReputation { get; set; } = 0;

    private async Task HandleCardClick()
    {
        if (OnStickerClick.HasDelegate)
            await OnStickerClick.InvokeAsync(Sticker);
    }

    private void NavigateToProfile()
    {
        if (!string.IsNullOrEmpty(OwnerUsername))
            Nav.NavigateTo($"/perfil/{Uri.EscapeDataString(OwnerUsername)}");
    }

    private void HandleOwnerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
            NavigateToProfile();
    }
}
