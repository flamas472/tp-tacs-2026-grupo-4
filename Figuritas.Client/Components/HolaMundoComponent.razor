
<MudPaper Style="padding: 1rem; border: 1px solid #3b82f6;">
    <MudText Typo="Typo.h6" Color="Color.Primary">@Titulo</MudText>
    <MudText>Soy un componente reutilizable. Me podés llamar desde cualquier lado.</MudText>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="Saludar" Style="margin-top: 1rem;">
        ¡Saludar!
    </MudButton>
</MudPaper>

@code {
    [Parameter] public string Titulo { get; set; } = "Título por defecto";

    private void Saludar()
    {
        // Esto solo imprime en la consola del navegador (F12)
        Console.WriteLine("¡Hola desde el componente de C#!");
    }
}