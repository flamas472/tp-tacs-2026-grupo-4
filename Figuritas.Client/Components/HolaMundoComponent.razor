
<div class="bg-white rounded-lg shadow-md p-4 border border-blue-500">
    <h4 class="text-gray-600">@Titulo</h4>
    <p>Soy un componente reutilizable. Me podés llamar desde cualquier lado.</p>
    <button class="border border-blue-500 text-blue-500 hover:bg-blue-500 hover:text-white px-4 py-2 rounded" @onclick="Saludar">¡Saludar!</button>
</div>

@code {
    [Parameter] public string Titulo { get; set; } = "Título por defecto";

    private void Saludar()
    {
        // Esto solo imprime en la consola del navegador (F12)
        Console.WriteLine("¡Hola desde el componente de C#!");
    }
}