@using Figuritas.Shared.Model
@using Figuritas.Shared.DTO.request
@using Figuritas.Client.Models
@using Figuritas.Client.Requests

@inject AuctionHttpClient AuctionHttp
@inject AuthStateService AuthState
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Publicar subasta</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @* ── Sección 1: selección / previsualización de la figurita a subastar ── *@
        <MudText Typo="Typo.subtitle2" Class="mb-1">Figurita a subastar</MudText>

        @if (Sticker is not null)
        {
            @* Figurita pre-seleccionada (flujo desde Repetidas) *@
            <MudPaper Class="auction-sticker-preview pa-3 mb-4" Elevation="0">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Figurita seleccionada</MudText>
                <div class="d-flex align-center gap-3 mt-1">
                    <img src="@Sticker.ImageUrl" class="auction-preview-img" alt="@Sticker.Description" />
                    <div>
                        <MudText Typo="Typo.subtitle2">#@Sticker.Number.ToString("D3") — @Sticker.Description</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Sticker.NationalTeam · @Sticker.Category</MudText>
                    </div>
                </div>
            </MudPaper>
        }
        else
        {
            @* Sin figurita previa: el usuario elige desde sus repetidas *@
            @if (selectedVm is not null)
            {
                <MudPaper Class="auction-sticker-preview pa-3 mb-2" Elevation="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Figurita seleccionada</MudText>
                    <div class="d-flex align-center gap-3 mt-1">
                        <img src="@selectedVm.Sticker.ImageUrl" class="auction-preview-img" alt="@selectedVm.Sticker.Description" />
                        <div class="flex-1">
                            <MudText Typo="Typo.subtitle2">
                                #@selectedVm.Sticker.Number.ToString("D3") — @selectedVm.Sticker.Description
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @selectedVm.Sticker.NationalTeam · @selectedVm.Sticker.Category
                            </MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Warning"
                                       OnClick="OpenStickerPicker"
                                       Disabled="loading" />
                    </div>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="auction-sticker-pick-placeholder pa-3 mb-2" Elevation="0">
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Elegí una figurita de tus repetidas para subastar.
                    </MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Inventory2"
                               Variant="Variant.Outlined"
                               Color="Color.Warning"
                               Size="Size.Small"
                               OnClick="OpenStickerPicker"
                               Disabled="loading">
                        Elegir figurita
                    </MudButton>
                </MudPaper>

                @if (showStickerValidation)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        Seleccioná una figurita para subastar.
                    </MudAlert>
                }
            }
        }

        <MudDivider Class="my-3" />

        @* ── Sección 2: figuritas mínimas de oferta ── *@
        <MudText Typo="Typo.subtitle2" Class="mb-1">
            Figuritas mínimas de oferta
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2" Style="font-size:0.8rem">
            Elegí las figuritas que querés recibir como mínimo a cambio.
        </MudText>
        <SelectedStickerListComponent SelectedStickers="@selectedStickers"
                                      OnSelectionChanged="@OnStickersChanged"
                                      Source="StickersSource.Catalog" />

        <MudDivider Class="my-4" />

        @* ── Sección 3: fecha y hora de cierre ── *@
        <MudText Typo="Typo.subtitle2" Class="mb-2">Fecha y hora de cierre</MudText>
        <div class="auction-datetime-row">
            <MudDatePicker Label="Fecha"
                           @bind-Date="endDate"
                           Margin="Margin.Dense"
                           Variant="Variant.Outlined"
                           DateFormat="dd/MM/yyyy"
                           MinDate="@DateTime.Today.AddDays(1)" />
            <MudTimePicker Label="Hora"
                           @bind-Time="endTime"
                           Margin="Margin.Dense"
                           Variant="Variant.Outlined"
                           AmPm="false" />
        </div>

        @if (feedbackMsg is not null)
        {
            <MudAlert Severity="@(feedbackSuccess ? Severity.Success : Severity.Error)"
                      Dense="true" Class="mt-3">
                @feedbackMsg
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="loading">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.Gavel"
                   OnClick="HandleSubmit"
                   Disabled="loading">
            @if (loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Publicar subasta
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    /// <summary>
    /// Dialog instance injected by MudBlazor's cascading parameter.
    /// </summary>
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>
    /// Pre-selected user sticker id. When 0 the user picks their sticker inside this dialog.
    /// </summary>
    [Parameter] public int UserStickerId { get; set; }

    /// <summary>
    /// Pre-selected sticker detail. When null the user picks their sticker inside this dialog.
    /// </summary>
    [Parameter] public Sticker? Sticker { get; set; }

    // Sticker chosen inside this dialog (only used when UserStickerId == 0)
    private UserStickerVm? selectedVm;

    // Whether to highlight missing sticker selection after a failed submit attempt
    private bool showStickerValidation = false;

    private List<Sticker> selectedStickers = new();
    private DateTime? endDate;
    private TimeSpan? endTime;
    private bool loading = false;
    private string? feedbackMsg;
    private bool feedbackSuccess = false;

    /// <summary>Returns the effective UserStickerId to submit (from parameter or inline selection).</summary>
    private int EffectiveUserStickerId =>
        UserStickerId != 0 ? UserStickerId : (selectedVm?.UserStickerId ?? 0);

    private void OnStickersChanged(List<Sticker> stickers) => selectedStickers = stickers;

    /// <summary>Opens UserStickerSelectionComponent as a dialog to pick a sticker from the user's repeated stickers.</summary>
    private async Task OpenStickerPicker()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<UserStickerSelectionComponent>(
            "Mis figuritas",
            new DialogParameters<UserStickerSelectionComponent>
            {
                { c => c.FilterByAuctionable, true }
            },
            options);
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is UserStickerVm picked)
        {
            selectedVm = picked;
            showStickerValidation = false;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        feedbackMsg = null;

        // Validate sticker selection when no pre-selected sticker was provided
        if (EffectiveUserStickerId == 0)
        {
            showStickerValidation = true;
            return;
        }

        if (endDate is null || endTime is null)
        {
            feedbackMsg = "Seleccioná la fecha y hora de cierre.";
            return;
        }

        var endsAt = endDate.Value.Date.Add(endTime.Value);
        if (endsAt <= DateTime.Now.AddMinutes(5))
        {
            feedbackMsg = "La fecha de cierre debe ser al menos 5 minutos en el futuro.";
            return;
        }

        loading = true;

        var token = await AuthState.GetTokenAsync() ?? string.Empty;
        var dto = new PostAuctionRequestDTO
        {
            UserStickerId = EffectiveUserStickerId,
            MinimumOfferStickerIds = selectedStickers.Select(s => s.Id).ToList(),
            EndsAt = endsAt
        };

        var result = await AuctionHttp.CreateAuctionAsync(dto, token);

        loading = false;
        feedbackSuccess = result.Success;
        feedbackMsg = result.Success
            ? "¡Subasta publicada correctamente!"
            : result.ErrorMessage ?? "Error al publicar la subasta.";

        if (feedbackSuccess)
        {
            await Task.Delay(1200);
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
